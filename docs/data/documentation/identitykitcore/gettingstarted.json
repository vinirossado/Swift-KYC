{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/GettingStarted"},"hierarchy":{"paths":[["doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore"]]},"kind":"article","metadata":{"role":"article","title":"Getting Started in 10 Lines","roleHeading":"Article","modules":[{"name":"IdentityKit"}]},"schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/HandlingErrors","doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/CustomizingAppearance"],"anchor":"Related-Documentation"},{"title":"Essentials","generated":true,"identifiers":["doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration","doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitEnvironment"],"anchor":"Essentials"}],"variants":[{"paths":["\/documentation\/identitykitcore\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Integrate identity verification into your app with just a few lines of code.","type":"text"}],"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"IdentityKit offers two APIs for running the verification flow: a "},{"inlineContent":[{"text":"delegate-based","type":"text"}],"type":"strong"},{"type":"text","text":" API for UIKit integration with fine-grained control, and an "},{"inlineContent":[{"text":"async\/await","type":"text"}],"type":"strong"},{"type":"text","text":" API for concise structured concurrency. Both start with the same configuration builder."}]},{"text":"Build a Configuration","type":"heading","anchor":"Build-a-Configuration","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"reference","isActive":true,"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration\/Builder"},{"type":"text","text":" to create a validated configuration. The builder requires an API key and a session ID at minimum. Call "},{"type":"reference","isActive":true,"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration\/Builder\/build()"},{"type":"text","text":" to validate and produce an immutable "},{"type":"reference","isActive":true,"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration"},{"type":"text","text":"."}]},{"code":["import IdentityKitCore","","let configuration = try IdentityKitConfiguration.Builder()","    .apiKey(\"ik_live_abc123\")","    .sessionId(\"sess_9f8e7d6c\")","    .environment(.production)","    .enabledChecks([.document(.idCard), .liveness])","    .theme(IdentityKitTheme(primaryColorHex: \"#1A73E8\"))","    .build()"],"type":"codeListing","syntax":"swift"},{"style":"tip","type":"aside","name":"Tip","content":[{"inlineContent":[{"text":"The builder defaults to ","type":"text"},{"code":".production","type":"codeVoice"},{"text":" environment, ","type":"text"},{"code":"[.document(.idCard), .liveness]","type":"codeVoice"},{"text":" checks, and the system-default theme. You only need to set the values you want to change.","type":"text"}],"type":"paragraph"}]},{"text":"Option A: Async\/Await API","type":"heading","anchor":"Option-A-AsyncAwait-API","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"The simplest integration path. Call "},{"type":"codeVoice","code":"IdentityKit.verify(configuration:presentingOn:)"},{"type":"text","text":" and await the result. The SDK presents the verification flow modally on the view controller you provide."}]},{"code":["import IdentityKitCore","import IdentityKitUI","","func startVerification() async {","    do {","        let config = try IdentityKitConfiguration.Builder()","            .apiKey(\"ik_live_abc123\")","            .sessionId(\"sess_9f8e7d6c\")","            .build()","","        let result = try await IdentityKit.verify(","            configuration: config,","            presentingOn: self","        )","        print(\"Verification completed: \\(result.sessionId)\")","    } catch {","        print(\"Verification failed: \\(error.localizedDescription)\")","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This is the recommended approach for new projects targeting iOS 15+."}]},{"text":"Option B: Delegate API","type":"heading","anchor":"Option-B-Delegate-API","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more control – such as receiving upload progress callbacks – use "},{"type":"codeVoice","code":"IdentityKit.verificationFlow(configuration:delegate:)"},{"type":"text","text":" which returns a "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" you present yourself."}]},{"code":["import IdentityKitCore","import IdentityKitUI","","class VerifyViewController: UIViewController, IdentityKitDelegate {","","    func startVerification() throws {","        let config = try IdentityKitConfiguration.Builder()","            .apiKey(\"ik_live_abc123\")","            .sessionId(\"sess_9f8e7d6c\")","            .build()","","        let flow = IdentityKit.verificationFlow(","            configuration: config,","            delegate: self","        )","        present(flow, animated: true)","    }","","    \/\/ MARK: - IdentityKitDelegate","","    func identityKitDidComplete(with result: VerificationResult) {","        dismiss(animated: true)","        print(\"Session \\(result.sessionId) completed at \\(result.completedAt)\")","    }","","    func identityKitDidFail(with error: IdentityKitError) {","        dismiss(animated: true)","        presentAlert(for: error)","    }","","    func identityKitDidCancel() {","        dismiss(animated: true)","    }","","    func identityKitUploadProgress(_ progress: Double) {","        progressBar.setProgress(Float(progress), animated: true)","    }","}"],"type":"codeListing","syntax":"swift"},{"style":"note","type":"aside","name":"Note","content":[{"inlineContent":[{"text":"All ","type":"text"},{"isActive":true,"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitDelegate","type":"reference"},{"text":" methods are called on the main actor. The ","type":"text"},{"code":"identityKitUploadProgress(_:)","type":"codeVoice"},{"text":" method has a default empty implementation, so it is optional to implement.","type":"text"}],"type":"paragraph"}]},{"text":"Add the Package Dependency","type":"heading","anchor":"Add-the-Package-Dependency","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add IdentityKit to your project using Swift Package Manager:"}]},{"code":["\/\/ Package.swift","dependencies: [","    .package(url: \"https:\/\/github.com\/your-org\/identity-kit.git\", from: \"1.0.0\")","]"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then add the modules you need to your target’s dependencies:"}]},{"code":[".target(","    name: \"YourApp\",","    dependencies: [","        \"IdentityKitCore\",","        \"IdentityKitUI\"","    ]",")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For most integrations, importing "},{"type":"codeVoice","code":"IdentityKitCore"},{"type":"text","text":" and "},{"type":"codeVoice","code":"IdentityKitUI"},{"type":"text","text":" is sufficient. The UI module transitively pulls in "},{"type":"codeVoice","code":"IdentityKitCapture"},{"type":"text","text":"."}]},{"text":"Camera Permission","type":"heading","anchor":"Camera-Permission","level":3},{"type":"paragraph","inlineContent":[{"type":"text","text":"IdentityKit requires camer