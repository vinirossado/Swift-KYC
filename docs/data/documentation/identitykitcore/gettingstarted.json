{"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/identitykitcore\/gettingstarted"]}],"abstract":[{"text":"Integrate identity verification into your app with just a few lines of code.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"identifier":{"url":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/GettingStarted","interfaceLanguage":"swift"},"kind":"article","hierarchy":{"paths":[["doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore"]]},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"inlineContent":[{"text":"IdentityKit offers two APIs for running the verification flow: a ","type":"text"},{"inlineContent":[{"text":"delegate-based","type":"text"}],"type":"strong"},{"text":" API for UIKit integration with fine-grained control, and an ","type":"text"},{"inlineContent":[{"type":"text","text":"async\/await"}],"type":"strong"},{"text":" API for concise structured concurrency. Both start with the same configuration builder.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Build a Configuration","level":3,"anchor":"Build-a-Configuration"},{"inlineContent":[{"text":"Use ","type":"text"},{"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration\/Builder","type":"reference","isActive":true},{"text":" to create a validated configuration. The builder requires an API key and a session ID at minimum. Call ","type":"text"},{"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration\/Builder\/build()","type":"reference","isActive":true},{"text":" to validate and produce an immutable ","type":"text"},{"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration","type":"reference","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"code":["import IdentityKitCore","","let configuration = try IdentityKitConfiguration.Builder()","    .apiKey(\"ik_live_abc123\")","    .sessionId(\"sess_9f8e7d6c\")","    .environment(.production)","    .enabledChecks([.document(.idCard), .liveness])","    .theme(IdentityKitTheme(primaryColorHex: \"#1A73E8\"))","    .build()"],"type":"codeListing","syntax":"swift"},{"type":"aside","name":"Tip","content":[{"inlineContent":[{"type":"text","text":"The builder defaults to "},{"code":".production","type":"codeVoice"},{"type":"text","text":" environment, "},{"code":"[.document(.idCard), .liveness]","type":"codeVoice"},{"type":"text","text":" checks, and the system-default theme. You only need to set the values you want to change."}],"type":"paragraph"}],"style":"tip"},{"type":"heading","text":"Option A: Async\/Await API","level":3,"anchor":"Option-A-AsyncAwait-API"},{"inlineContent":[{"type":"text","text":"The simplest integration path. Call "},{"code":"IdentityKit.verify(configuration:presentingOn:)","type":"codeVoice"},{"type":"text","text":" and await the result. The SDK presents the verification flow modally on the view controller you provide."}],"type":"paragraph"},{"code":["import IdentityKitCore","import IdentityKitUI","","func startVerification() async {","    do {","        let config = try IdentityKitConfiguration.Builder()","            .apiKey(\"ik_live_abc123\")","            .sessionId(\"sess_9f8e7d6c\")","            .build()","","        let result = try await IdentityKit.verify(","            configuration: config,","            presentingOn: self","        )","        print(\"Verification completed: \\(result.sessionId)\")","    } catch {","        print(\"Verification failed: \\(error.localizedDescription)\")","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"This is the recommended approach for new projects targeting iOS 15+.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Option B: Delegate API","level":3,"anchor":"Option-B-Delegate-API"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more control – such as receiving upload progress callbacks – use "},{"type":"codeVoice","code":"IdentityKit.verificationFlow(configuration:delegate:)"},{"type":"text","text":" which returns a "},{"type":"codeVoice","code":"UIViewController"},{"type":"text","text":" you present yourself."}]},{"type":"codeListing","syntax":"swift","code":["import IdentityKitCore","import IdentityKitUI","","class VerifyViewController: UIViewController, IdentityKitDelegate {","","    func startVerification() throws {","        let config = try IdentityKitConfiguration.Builder()","            .apiKey(\"ik_live_abc123\")","            .sessionId(\"sess_9f8e7d6c\")","            .build()","","        let flow = IdentityKit.verificationFlow(","            configuration: config,","            delegate: self","        )","        present(flow, animated: true)","    }","","    \/\/ MARK: - IdentityKitDelegate","","    func identityKitDidComplete(with result: VerificationResult) {","        dismiss(animated: true)","        print(\"Session \\(result.sessionId) completed at \\(result.completedAt)\")","    }","","    func identityKitDidFail(with error: IdentityKitError) {","        dismiss(animated: true)","        presentAlert(for: error)","    }","","    func identityKitDidCancel() {","        dismiss(animated: true)","    }","","    func identityKitUploadProgress(_ progress: Double) {","        progressBar.setProgress(Float(progress), animated: true)","    }","}"]},{"type":"aside","name":"Note","content":[{"inlineContent":[{"text":"All ","type":"text"},{"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitDelegate","isActive":true,"type":"reference"},{"text":" methods are called on the main actor. The ","type":"text"},{"code":"identityKitUploadProgress(_:)","type":"codeVoice"},{"text":" method has a default empty implementation, so it is optional to implement.","type":"text"}],"type":"paragraph"}],"style":"note"},{"type":"heading","text":"Add the Package Dependency","level":3,"anchor":"Add-the-Package-Dependency"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add IdentityKit to your project using Swift Package Manager:"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ Package.swift","dependencies: [","    .package(url: \"https:\/\/github.com\/your-org\/identity-kit.git\", from: \"1.0.0\")","]"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Then add the modules you need to your target’s dependencies:"}]},{"type":"codeListing","syntax":"swift","code":[".target(","    name: \"YourApp\",","    dependencies: [","        \"IdentityKitCore\",","        \"IdentityKitUI\"","    ]",")"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For most integrations, importing "},{"type":"codeVoice","code":"IdentityKitCore"},{"type":"text","text":" and "},{"type":"codeVoice","code":"IdentityKitUI"},{"type":"text","text":" is sufficient. The UI module transitively pulls in "},{"type":"codeVoice","code":"IdentityKitCapture"},{"type":"text","text":"."}]},{"type":"heading","text":"Camera Permission","level":3,"anchor":"Camera-Permission"},{"type":"paragraph","inlineContent":[{"type":"text","text":"IdentityKit requires camera access for document capture and liveness detection. Add the "},{"type":"codeVoice","code":"NSCameraUsageDescription"},{"type":"text","text":" key to your app’s "},{"type":"codeVoice","code":"Info.plist"},{"text":":","type":"text"}]},{"syntax":"xml","code":["<key>NSCameraUsageDescription<\/key>","<string>We need camera access to verify your identity document and perform a liveness check.<\/string>"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the user denies camera permission, the SDK reports "},{"isActive":true,"type":"reference","identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitError\/cameraPermissionDenied"},{"type":"text","text":"."}]}],"kind":"content"}],"metadata":{"role":"article","modules":[{"name":"IdentityKit"}],"roleHeading":"Article","title":"Getting Started in 10 Lines"},"sections":[],"seeAlsoSections":[{"identifiers":["doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/HandlingErrors","doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/CustomizingAppearance"],"anchor":"Related-Documentation","title":"Related Documentation"},{"identifiers":["doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration","doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitEnvironment"],"anchor":"Essentials","title":"Essentials","generated":true}],"references":{"doc://io.identitykit.IdentityKitCore/documentation/IdentityKitCore/IdentityKitError/cameraPermissionDenied":{"url":"\/documentation\/identitykitcore\/identitykiterror\/camerapermissiondenied","kind":"symbol","identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitError\/cameraPermissionDenied","abstract":[{"type":"text","text":"Camera permission was denied or restricted by the user."}],"role":"symbol","type":"topic","title":"IdentityKitError.cameraPermissionDenied","fragments":[{"text":"case","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"cameraPermissionDenied"}]},"doc://io.identitykit.IdentityKitCore/documentation/IdentityKitCore/IdentityKitConfiguration":{"role":"symbol","url":"\/documentation\/identitykitcore\/identitykitconfiguration","navigatorTitle":[{"text":"IdentityKitConfiguration","kind":"identifier"}],"type":"topic","abstract":[{"type":"text","text":"Immutable configuration for an IdentityKit verification session."}],"kind":"symbol","fragments":[{"text":"struct","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IdentityKitConfiguration","kind":"identifier"}],"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/