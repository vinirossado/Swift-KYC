ragraph","inlineContent":[{"type":"codeVoice","code":"\"#000000\""}]}],[{"type":"paragraph","inlineContent":[{"text":"Text color for instructions, labels, and body copy.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"cornerRadius"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Double"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"12.0"}]}],[{"type":"paragraph","inlineContent":[{"text":"Corner radius applied to buttons, cards, and capture overlays.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"fontName"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"String?"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"nil"}]}],[{"type":"paragraph","inlineContent":[{"text":"Custom font name. When ","type":"text"},{"type":"codeVoice","code":"nil"},{"text":", the SDK uses the system font.","type":"text"}]}]]],"type":"table","header":"row"},{"level":3,"text":"Color Format","anchor":"Color-Format","type":"heading"},{"inlineContent":[{"type":"text","text":"Colors are specified as hex strings with a leading "},{"type":"codeVoice","code":"#"},{"type":"text","text":". The SDK supports both 6-digit ("},{"type":"codeVoice","code":"#RRGGBB"},{"type":"text","text":") and 8-digit ("},{"type":"codeVoice","code":"#RRGGBBAA"},{"type":"text","text":") formats:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Opaque blue","IdentityKitTheme(primaryColorHex: \"#1A73E8\")","","\/\/ Semi-transparent overlay","IdentityKitTheme(backgroundColorHex: \"#00000080\")"]},{"level":3,"text":"Using the Default Theme","anchor":"Using-the-Default-Theme","type":"heading"},{"inlineContent":[{"type":"text","text":"If you do not specify a theme, the SDK uses "},{"isActive":true,"type":"reference","identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitTheme\/default"},{"type":"text","text":" which matches the iOS system appearance:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ These are equivalent:","let config1 = try IdentityKitConfiguration.Builder()","    .apiKey(\"ik_live_abc123\")","    .sessionId(\"sess_9f8e7d6c\")","    .build()","","let config2 = try IdentityKitConfiguration.Builder()","    .apiKey(\"ik_live_abc123\")","    .sessionId(\"sess_9f8e7d6c\")","    .theme(.default)","    .build()"]},{"level":3,"text":"Custom Fonts","anchor":"Custom-Fonts","type":"heading"},{"inlineContent":[{"type":"text","text":"When you set "},{"type":"codeVoice","code":"fontName"},{"type":"text","text":", the SDK uses your custom font for all labels, buttons, and instruction text. Make sure the font is bundled in your app target and registered in your "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" under "},{"type":"codeVoice","code":"UIAppFonts"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"xml","type":"codeListing","code":["<key>UIAppFonts<\/key>","<array>","    <string>Avenir-Medium.ttf<\/string>","<\/array>"]},{"inlineContent":[{"type":"text","text":"Then reference it by its PostScript name:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["IdentityKitTheme(fontName: \"Avenir-Medium\")"]},{"name":"Important","type":"aside","style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"If the specified font name cannot be resolved at runtime, the SDK falls back to the system font silently. No error is thrown.","type":"text"}]}]},{"level":3,"text":"What Gets Themed","anchor":"What-Gets-Themed","type":"heading"},{"inlineContent":[{"type":"text","text":"The theme applies to the following UI elements across all verification screens:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Buttons"}]},{"type":"text","text":" – primary color fill, corner radius, and font."}],"type":"paragraph"}]},{"