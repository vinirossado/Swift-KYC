{"identifier":{"url":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/CustomizingAppearance","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore"]]},"metadata":{"title":"Customizing Appearance","roleHeading":"Article","modules":[{"name":"IdentityKit"}],"role":"article"},"kind":"article","schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitTheme","doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/GettingStarted"],"anchor":"Related-Documentation"},{"title":"Appearance","identifiers":["doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitTheme"],"generated":true,"anchor":"Appearance"}],"variants":[{"paths":["\/documentation\/identitykitcore\/customizingappearance"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Match the IdentityKit verification screens to your app’s brand identity."}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"text":"IdentityKit separates theme data from UIKit rendering. The ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitTheme"},{"type":"text","text":" struct lives in "},{"type":"codeVoice","code":"IdentityKitCore"},{"type":"text","text":" (no UIKit dependency), while the "},{"type":"codeVoice","code":"IdentityKitUI"},{"type":"text","text":" module reads the theme at runtime and applies it to all verification screens. This means you can configure appearance without importing UIKit yourself."}],"type":"paragraph"},{"level":3,"text":"Creating a Custom Theme","anchor":"Creating-a-Custom-Theme","type":"heading"},{"inlineCont