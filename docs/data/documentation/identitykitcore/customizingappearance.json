K uses the system font.","type":"text"}]}]]]},{"text":"Color Format","level":3,"type":"heading","anchor":"Color-Format"},{"inlineContent":[{"text":"Colors are specified as hex strings with a leading ","type":"text"},{"code":"#","type":"codeVoice"},{"text":". The SDK supports both 6-digit (","type":"text"},{"code":"#RRGGBB","type":"codeVoice"},{"text":") and 8-digit (","type":"text"},{"code":"#RRGGBBAA","type":"codeVoice"},{"text":") formats:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ Opaque blue","IdentityKitTheme(primaryColorHex: \"#1A73E8\")","","\/\/ Semi-transparent overlay","IdentityKitTheme(backgroundColorHex: \"#00000080\")"]},{"text":"Using the Default Theme","level":3,"type":"heading","anchor":"Using-the-Default-Theme"},{"inlineContent":[{"text":"If you do not specify a theme, the SDK uses ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitTheme\/default"},{"text":" which matches the iOS system appearance:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["\/\/ These are equivalent:","let config1 = try IdentityKitConfiguration.Builder()","    .apiKey(\"ik_live_abc123\")","    .sessionId(\"sess_9f8e7d6c\")","    .build()","","let config2 = try IdentityKitConfiguration.Builder()","    .apiKey(\"ik_live_abc123\")","    .sessionId(\"sess_9f8e7d6c\")","    .theme(.default)","    .build()"]},{"text":"Custom Fonts","level":3,"type":"heading","anchor":"Custom-Fonts"},{"inlineContent":[{"text":"When you set ","type":"text"},{"code":"fontName","type":"codeVoice"},{"text":", the SDK uses your custom font for all labels, buttons, and instruction text. Make sure the font is bundled in your app target and registered in your ","type":"text"},{"code":"Info.plist","type":"codeVoice"},{"text":" under ","type":"text"},{"code":"UIAppFonts","type":"codeVoice"},{"text":":","type":"text"}],"type":"parag