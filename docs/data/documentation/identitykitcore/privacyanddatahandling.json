ntation\/IdentityKitCore\/IdentityKitTelemetry","fragments":[{"text":"protocol","kind":"keyword"},{"text":" ","kind":"text"},{"text":"IdentityKitTelemetry","kind":"identifier"}],"type":"topic","title":"IdentityKitTelemetry"},"doc://io.identitykit.IdentityKitCore/documentation/IdentityKitCore/HandlingErrors":{"url":"\/documentation\/identitykitcore\/handlingerrors","identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/HandlingErrors","kind":"article","type":"topic","role":"article","abstract":[{"text":"Understand and recover from errors that occur during the identity verification flow.","type":"text"}],"title":"Handling Errors"},"doc://io.identitykit.IdentityKitCore/documentation/IdentityKitCore/IdentityKitConfiguration/Builder/logLevel(_:)":{"url":"\/documentation\/identitykitcore\/identitykitconfiguration\/builder\/loglevel(_:)","identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration\/Builder\/logLevel(_:)","kind":"symbol","type":"topic","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"logLevel","kind":"identifier"},{"text":"(","kind":"text"},{"text":"LogLevel","preciseIdentifier":"s:15IdentityKitCore8LogLevelO","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Builder","preciseIdentifier":"s:15IdentityKitCore0aB13ConfigurationV7BuilderC","kind":"typeIdentifier"}],"abstract":[],"title":"logLevel(_:)"},"doc://io.identitykit.IdentityKitCore/documentation/IdentityKitCore/IdentityKitError/circuitBreakerOpen":{"url":"\/documentation\/identitykitcore\/identitykiterror\/circuitbreakeropen","identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitError\/circuitBreakerOpen","kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"case"},{"kind":"text","text":" "},{"kind":"identifier","text":"circuitBreakerOpen"}],"abstract":[{"text":"The circuit breaker is o