{"identifier":{"url":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/PrivacyAndDataHandling","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore"]]},"metadata":{"roleHeading":"Article","title":"Privacy and Data Handling","modules":[{"name":"IdentityKit"}],"role":"article"},"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitError","doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/HandlingErrors"],"anchor":"Related-Documentation"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/identitykitcore\/privacyanddatahandling"]}],"abstract":[{"text":"How IdentityKit protects user data throughout the verification flow.","type":"text"}],"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"IdentityKit is designed with a privacy-first approach. The SDK handles sensitive personal data – identity documents and biometric liveness frames – and applies multiple layers of protection to ensure this data is secured in transit, at rest, and in logs.","type":"text"}]},{"anchor":"Zero-Third-Party-Dependencies","text":"Zero Third-Party Dependencies","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"IdentityKit has no third-party dependencies. Every component – networking, storage, image processing – is implemented using Apple frameworks only. This eliminates supply-chain risk and ensures no user data is shared with external libraries.","type":"text"}]},{"anchor":"Data-in-Transit","text":"Data in Transit","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"All network communication enforces strict security:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"App Transport Security (ATS):"}]},{"text":" The SDK requires ATS with no exceptions. All API endpoints use HTTPS with TLS 1.2 or later.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Certificate Pinning:"}]},{"text":" The ","type":"text"},{"type":"codeVoice","code":"IdentityKitNetwork"},{"text":" module pins the expected server certificates. Connections to servers presenting unexpected certificates are rejected immediately.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Request Signing:"}]},{"text":" When an HMAC secret is provided via ","type":"text"},{"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration\/Builder\/hmacSecret(_:)","isActive":true,"type":"reference"},{"text":", every API request is signed. The backend can verify request integrity and authenticity.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Data-at-Rest","text":"Data at Rest","type":"heading","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Keychain Storage:"}]},{"text":" Session tokens and API keys are stored in the iOS Keychain via the ","type":"text"},{"type":"codeVoice","code":"IdentityKitStorage"},{"text":" module, not in ","type":"text"},{"type":"codeVoice","code":"UserDefaults"},{"text":" or on disk.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"No Persistent Image Storage:"}]},{"text":" Captured document images and liveness frames are held in memory only. They are written to the upload outbox queue as encrypted temporary files and deleted immediately after successful upload.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Background Upload Queue:"}]},{"text":" If the app is backgrounded or the network is unavailable, the outbox queue retains encrypted payloads for upload on next launch. Once uploaded, all temporary files are purged.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Logging","text":"Logging","type":"heading","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"No PII in Logs:"}]},{"text":" The SDK’s internal logger (","type":"text"},{"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitLogger","isActive":true,"type":"reference"},{"text":") never includes personally identifiable information in log output. Session IDs are truncated, and image data is never logged.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Configurable Log Level:"}]},{"text":" Set the log level via ","type":"text"},{"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration\/Builder\/logLevel(_:)","isActive":true,"type":"reference"},{"text":" to control verbosity. In production, use ","type":"text"},{"type":"codeVoice","code":".warning"},{"text":" or ","type":"text"},{"type":"codeVoice","code":".error"},{"text":" to minimize log output. Set ","type":"text"},{"type":"codeVoice","code":".none"},{"text":" to disable SDK logging entirely.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Custom Logger Integration:"}]},{"text":" Implement the ","type":"text"},{"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitLogger","isActive":true,"type":"reference"},{"text":" protocol to route SDK logs into your own logging infrastructure with your own redaction rules.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Camera-and-Permissions","text":"Camera and Permissions","type":"heading","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Minimal Permission Scope:"}]},{"text":" The SDK requests only camera access (","type":"text"},{"type":"codeVoice","code":"NSCameraUsageDescription"},{"text":"). It does not request photo library, microphone, or location access.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Graceful Denial:"}]},{"text":" If camera permission is denied, the SDK reports ","type":"text"},{"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitError\/cameraPermissionDenied","isActive":true,"type":"reference"},{"text":" and does not attempt to access the camera.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Network-Resilience-and-Data-Protection","text":"Network Resilience and Data Protection","type":"heading","level":3},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Retry with Backoff:"}]},{"text":" Failed uploads are retried with exponential backoff. The maximum number of attempts is configurable via ","type":"text"},{"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitConfiguration\/Builder\/maxRetryAttempts(_:)","isActive":true,"type":"reference"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Circuit Breaker:"}]},{"text":" After repeated backend failures, the circuit breaker opens to prevent further requests. This protects both the user’s device (battery, bandwidth) and the backend from cascading load. The SDK reports ","type":"text"},{"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitError\/circuitBreakerOpen","isActive":true,"type":"reference"},{"text":" so your app can inform the user.","type":"text"}]}]}],"type":"unorderedList"},{"anchor":"Telemetry","text":"Telemetry","type":"heading","level":3},{"type":"paragraph","inlineContent":[{"text":"The optional ","type":"text"},{"isActive":true,"identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitTelemetry","type":"reference"},{"text":" protocol allows you to track SDK events and performance metrics. The SDK itself does not send any telemetry data to Anthropic or any third party. If you implement the protocol, you control where the data goes.","type":"text"}]},{"anchor":"Summary-of-Security-Controls","text":"Summary of Security Controls","type":"heading","level":3},{"type":"table","header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Layer"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mechanism"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Transport"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"TLS 1.2+, ATS strict, certificate pinning"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Request integrity"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"HMAC request signing (optional)"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Storage"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"iOS Keychain for secrets, encrypted temp files for media"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Logging"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"No PII, configurable level, custom logger support"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Permissions"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Camera only, graceful denial handling"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Resilience"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Retry with backoff, circuit breaker"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Dependencies"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Zero third-party libraries"}]}]]]}],"kind":"content"}],"references":{"doc://io.identitykit.IdentityKitCore/documentation/IdentityKitCore/IdentityKitError":{"url":"\/documentation\/identitykitcore\/identitykiterror","identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitError","navigatorTitle":[{"kind":"identifier","text":"IdentityKitError"}],"kind":"symbol","type":"topic","role":"symbol","fragments":[{"kind":"keyword","text":"enum"},{"kind":"text","text":" "},{"kind":"identifier","text":"IdentityKitError"}],"abstract":[{"text":"Errors that can occur during the IdentityKit verification flow.","type":"text"}],"title":"IdentityKitError"},"doc://io.identitykit.IdentityKitCore/documentation/IdentityKitCore":{"url":"\/documentation\/identitykitcore","role":"collection","title":"IdentityKit","identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore","abstract":[{"type":"text","text":"A modular iOS SDK for identity verification (KYC) with document capture and liveness detection."}],"kind":"symbol","type":"topic"},"doc://io.identitykit.IdentityKitCore/documentation/IdentityKitCore/IdentityKitLogger":{"role":"symbol","abstract":[{"type":"text","text":"Abstraction for SDK logging. Host apps provide an implementation"},{"type":"text","text":" "},{"type":"text","text":"to route SDK logs into their own logging infrastructure."}],"url":"\/documentation\/identitykitcore\/identitykitlogger","navigatorTitle":[{"text":"IdentityKitLogger","kind":"identifier"}],"kind":"symbol","identifier":"doc:\/\/io.identitykit.IdentityKitCore\/documentation\/IdentityKitCore\/IdentityKitLogger","fragments":[{"text":"protocol","kind":"keyword"},{"